{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"${HOME}/.claude/brain-config.json\" ]; then bash \"${CLAUDE_PLUGIN_ROOT}/scripts/sync.sh\" --quiet --auto-merge; fi",
            "timeout": 30,
            "async": true,
            "statusMessage": "Syncing brain..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"${HOME}/.claude/brain-config.json\" ]; then bash \"${CLAUDE_PLUGIN_ROOT}/scripts/snapshot.sh\" --quiet || true; fi",
            "timeout": 15,
            "async": true,
            "statusMessage": "Saving brain..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"${HOME}/.claude/brain-config.json\" ]; then bash \"${CLAUDE_PLUGIN_ROOT}/scripts/export.sh\" --memory-only --quiet > /dev/null; fi",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
